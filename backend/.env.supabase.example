# ========================================
# SUPABASE DATABASE CONFIGURATION
# ========================================

# Get this from: Supabase Dashboard → Settings → Database → Connection String (URI)
# Format: postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxx:your-password@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Server Configuration
PORT=8080
GIN_MODE=release

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET=change-this-to-a-random-secure-string

# CORS - Allow all origins (or specify your frontend URLs)
ALLOWED_ORIGINS=*

{
  "expo": {
    "name": "ONE RIDE",
    "slug": "oneride-balingasag",
    "scheme": "oneride",
    "version": "1.0.9",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#DC2626"
    },
    "assetBundlePatterns": [
      "assets/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oneridebalingasag.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ONE RIDE needs your location to provide ride and delivery services.",
        "NSLocationAlwaysUsageDescription": "ONE RIDE needs your location for real-time tracking.",
        "NSCameraUsageDescription": "ONE RIDE needs camera access to upload item photos.",
        "NSPhotoLibraryUsageDescription": "ONE RIDE needs access to your photos.",
        "LSApplicationQueriesSchemes": [
          "gcash",
          "paymaya"
        ]
      }
    },
    "android": {
      "versionCode": 26,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      },
      "package": "com.oneridebalingasag.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidQueries",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ONE RIDE to use your location for ride and delivery tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#3B82F6"
        }
      ],
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": false,
            "enableMinifyInReleaseBuilds": true
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 5000,
      "url": "https://u.expo.dev/cab13cc8-1629-4a45-835d-6eb9a5ff9204"
    },
    "owner": "omjidev",
    "extra": {
      "eas": {
        "projectId": "cab13cc8-1629-4a45-835d-6eb9a5ff9204"
      }
    },
    "runtimeVersion": "1.0.0"
  }
}
